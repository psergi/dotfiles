[user]
	# These values are set in ~/.gitconfig_local
[include]
	path = ~/.gitconfig_local
[color]
	ui = true
[color "branch"]
	current = yellow reverse
	local = yellow
	remote = green
[color "diff"]
	meta = yellow bold
	frag = magenta bold
	old = red
	new = green
[merge]
	tool = vimdiff
[init]
	defaultBranch = main
[core]
	excludesfile = /Users/phil.sergi/.gitignore_global
